# xAPI MCP Server Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- LRS Backend Selection ---
# Options: generic, ralph, veracity
LRS_PLUGIN=generic

# --- Generic / Any xAPI-compliant LRS ---
LRS_ENDPOINT=https://your-lrs.example.com/xapi
LRS_USERNAME=your_username
LRS_PASSWORD=your_password

# --- Ralph LRS (optional overrides) ---
# RALPH_ENDPOINT=https://ralph.example.com
# RALPH_CLIENT_ID=your_client_id
# RALPH_CLIENT_SECRET=your_client_secret

# --- Veracity Learning LRS (optional) ---
# VERACITY_ENDPOINT=https://lrs.io/v1/lrs/your_lrs_id/
# VERACITY_KEY=your_api_key
# VERACITY_SECRET=your_api_secret

# --- Server tuning ---
# Request timeout in seconds (default: 30)
LRS_TIMEOUT=30
