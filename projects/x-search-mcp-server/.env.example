# X (Twitter) API credentials
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Get credentials at: https://developer.x.com/en/portal/dashboard
# Free tier: 500k tweet reads/month, recent search (7 days)
# Basic tier ($100/mo): full archive search

# Required: App-only Bearer Token (read-only search)
X_BEARER_TOKEN=your_bearer_token_here

# Optional: OAuth 2.0 for user-context requests (e.g. reading DMs, protected tweets)
# X_CLIENT_ID=your_client_id
# X_CLIENT_SECRET=your_client_secret

# Optional: max results cap per request (default 10, max 100 for recent search)
X_DEFAULT_MAX_RESULTS=10
